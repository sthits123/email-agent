# OpenAI API Key for the agent's LLM
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Gmail credentials as JSON strings (if not using .secrets/ folder)
# GMAIL_TOKEN='{"token": "...", "refresh_token": "...", ...}'
# GMAIL_SECRET='{"installed": {"client_id": "...", "client_secret": "...", ...}}'

# LangGraph / LangChain configuration (Optional, for LangGraph Studio)
# LANGCHAIN_API_KEY=your_langchain_api_key_here
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=email-assistant
